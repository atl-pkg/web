// Minimal tokenizer test
enum TplToken {
    Text(string),
    Expr(string),
}

fn indexOf_from(source: string, needle: string, pos: number): Option<number> {
    let tail = source.slice(pos, source.length());
    let rel = tail.indexOf(needle);
    match rel {
        None => { return None; },
        Some(i) => { return Some(i + pos); },
    }
}

fn tokenize(source: string): TplToken[] {
    let mut tokens: TplToken[] = [];
    let mut pos = 0;
    let len = source.length();

    while pos < len {
        let expr_open_opt = indexOf_from(source, "{{", pos);
        let next_expr = match expr_open_opt { Some(i) => i, None => len + 1 };

        if next_expr < len {
            if next_expr > pos {
                tokens.push(Text(source.slice(pos, next_expr)));
            }
            let close_opt = indexOf_from(source, "}}", next_expr + 2);
            match close_opt {
                None => {
                    tokens.push(Text(source.slice(next_expr, len)));
                    pos = len;
                },
                Some(close) => {
                    let expr = source.slice(next_expr + 2, close).trim();
                    tokens.push(Expr(expr));
                    pos = close + 2;
                },
            }
        } else {
            tokens.push(Text(source.slice(pos, len)));
            pos = len;
        }
    }

    return tokens;
}

let tokens = tokenize("Hello {{ name }}!");
tokens.length();
