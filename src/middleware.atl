// Middleware — composable request/response pipeline
//
// Usage:
//   import { chain, logger, cors, json_body } from 'web';
//   const stack = chain([logger(), cors("*"), json_body()]);
//   http.serve(3000, stack(router.handle));

export type Handler = any;
export type Middleware = any;

// Compose a list of middleware around a final handler.
// Middleware is applied left-to-right (first in list = outermost).
export fn chain(middleware: Middleware[], handler: Handler): Handler {
    let mut h = handler;
    let mut i = middleware.length() - 1;
    while i >= 0 {
        h = middleware[i](h);
        i = i - 1;
    }
    return h;
}

// ── built-in middleware ───────────────────────────────────────────────────────

// Request/response logger. Prints method, path, status, duration.
export fn logger(): Middleware {
    return fn(next: Handler): Handler {
        return fn(req: any, res: any): any {
            let start = datetime.now().timestamp();
            let result = next(req, res);
            let duration = datetime.now().timestamp() - start;
            console.log(`${req.method} ${req.path} ${result.status} (${duration}ms)`);
            return result;
        };
    };
}

// CORS headers. Pass "*" to allow all origins.
export fn cors(origin: string): Middleware {
    return fn(next: Handler): Handler {
        return fn(req: any, res: any): any {
            // Handle preflight
            if req.method == "OPTIONS" {
                return res
                    .status(204)
                    .header("Access-Control-Allow-Origin", origin)
                    .header("Access-Control-Allow-Methods", "GET, POST, PUT, DELETE, PATCH, OPTIONS")
                    .header("Access-Control-Allow-Headers", "Content-Type, Authorization");
            }

            let result = next(req, res);
            return result.header("Access-Control-Allow-Origin", origin);
        };
    };
}

// Parse JSON body and attach to req.json.
// If body is not valid JSON, returns 400 Bad Request.
export fn json_body(): Middleware {
    return fn(next: Handler): Handler {
        return fn(req: any, res: any): any {
            let ct = req.headers["content-type"];
            if ct != None && unwrap(ct).includes("application/json") {
                let parsed = json.parse(req.body);
                match parsed {
                    Err(_) => { return res.status(400).text("Invalid JSON body"); },
                    Ok(data) => req.json = Some(data),
                }
            }
            return next(req, res);
        };
    };
}

// Rate limiter — simple in-memory request counter per IP.
// max_requests per window_ms milliseconds.
export fn rate_limit(max_requests: number, window_ms: number): Middleware {
    let mut counters = new Map<string, number>();
    let mut window_start = datetime.now().timestamp();

    return fn(next: Handler): Handler {
        return fn(req: any, res: any): any {
            let now = datetime.now().timestamp();

            // Reset window
            if now - window_start > window_ms {
                counters = new Map<string, number>();
                window_start = now;
            }

            let ip = unwrap_or(req.headers["x-forwarded-for"], req.remote_addr);
            let count = unwrap_or(counters.get(ip), 0) + 1;
            counters.set(ip, count);

            if count > max_requests {
                return res
                    .status(429)
                    .header("Retry-After", math.ceil(window_ms / 1000).toString())
                    .text("Too Many Requests");
            }

            return next(req, res);
        };
    };
}

// Basic auth middleware.
export fn basic_auth(validate: any): Middleware {
    return fn(next: Handler): Handler {
        return fn(req: any, res: any): any {
            let auth: Option<string> = req.headers["authorization"];
            if auth == None {
                return res
                    .status(401)
                    .header("WWW-Authenticate", "Basic realm=\"Protected\"")
                    .text("Unauthorized");
            }

            let parts = unwrap(auth).split(" ");
            if parts.length() != 2 || parts[0] != "Basic" {
                return res.status(400).text("Bad Authorization header");
            }

            let decoded = encoding.base64Decode(parts[1]);
            let credentials = decoded.split(":");
            if credentials.length() < 2 {
                return res.status(400).text("Bad credentials format");
            }

            let username = credentials[0];
            let password = credentials.slice(1, credentials.length()).join(":");

            if !validate(username, password) {
                return res.status(401).text("Invalid credentials");
            }

            return next(req, res);
        };
    };
}
