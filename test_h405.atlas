import { Router, RouteMatch } from "./src/router";
import { render } from "./src/template";

// Test router
let mut router = Router { routes: [] };
router = router.get("/users/:id", fn(req, res) { return res; });
router = router.post("/users", fn(req, res) { return res; });

let m = router.find("GET", "/users/42");
match m {
    Some(route_match) => {
        let id = unwrap_or(route_match.params.get("id"), "unknown");
        id;
    },
    None => { "no match"; },
}
