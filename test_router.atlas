import { Router, RouteMatch } from "./src/router";

let mut router = Router { routes: [] };
router = router.get("/users/:id", fn(req: any, res: any): any { return res; });

let m = router.find("GET", "/users/42");
match m {
    Some(route_match) => { console.log("matched! id=" + unwrap(route_match.params.get("id"))); },
    None => { console.log("FAIL: no match"); },
}
