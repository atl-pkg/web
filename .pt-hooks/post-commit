#!/bin/bash

# pt:session-commit — auto-records commit SHA to active pt session
_pt_track_commit() {
    local db="$HOME/.project-tracker/web/tracking.db"
    [[ ! -f "$db" ]] && return 0
    local sha
    sha=$(git rev-parse --short HEAD 2>/dev/null)
    [[ -z "$sha" ]] && return 0
    local session_id
    session_id=$(sqlite3 "$db" "SELECT last_session_id FROM state WHERE id=1" 2>/dev/null)
    [[ -z "$session_id" ]] && return 0
    local is_active
    is_active=$(sqlite3 "$db" "SELECT 1 FROM sessions WHERE id='$session_id' AND ended_at IS NULL" 2>/dev/null)
    [[ -z "$is_active" ]] && return 0
    local current
    current=$(sqlite3 "$db" "SELECT COALESCE(git_commits,'') FROM sessions WHERE id='$session_id'" 2>/dev/null)
    if [[ -z "$current" ]]; then
        sqlite3 "$db" "UPDATE sessions SET git_commits='$sha' WHERE id='$session_id'" 2>/dev/null
    elif [[ "$current" != *"$sha"* ]]; then
        sqlite3 "$db" "UPDATE sessions SET git_commits='$current,$sha' WHERE id='$session_id'" 2>/dev/null
    fi
}
_pt_track_commit
